<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Webfetch</title>
    <link rel="stylesheet" href="/static/css/reset.css"> 
    <link rel="stylesheet" href="/static/css/style.css">
  </head>
  <body>
    <main>
      <div class="fastfetch-logo"></div>
      <div class="fastfetch-text-container">
        <ul class="fastfetch-text">
          {{range .FastFetch}}
          <li class="fastfetch-text-line">
            <p class="fastfetch-text-line-key">{{.Key}}</p>
            <p class="fastfetch-text-line-separator">:&nbsp;</p>
            <p class="fastfetch-text-line-value">{{.Value}}</p>
          </li>
          {{end}}
        </ul>
      </div>
    </main>
    <script src="/static/js/script.js"></script>
  </body>
</html>
